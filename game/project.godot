QuestManager="*res://scripts/quest/quest_manager.gd"
DialogueManager="*res://scripts/dialogue/dialogue_manager.gd"
InventoryManager="*res://scripts/inventory/inventory_manager.gd"
ReputationManager="*res://scripts/reputation/reputation_manager.gd"

