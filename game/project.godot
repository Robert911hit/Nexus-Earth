; Engine configuration file.
; Nexus Earth uses Godot 4.x and GDScript.

config_version=5

[application]

config/name="Nexus Earth"
config/description="Open-world RPG foundation for Nexus Earth."
run/main_scene="res://scenes/demo/first_playable_demo.tscn"
config/features=PackedStringArray("4.2")

[autoload]

SaveSystem="*res://scripts/systems/save_system.gd"
QuestManager="*res://scripts/quest/quest_manager.gd"
DialogueManager="*res://scripts/dialogue/dialogue_manager.gd"
InventoryManager="*res://scripts/inventory/inventory_manager.gd"
ReputationManager="*res://scripts/reputation/reputation_manager.gd"

[input]

move_forward={"deadzone":0.5,"events":[Object(InputEventKey,"physical_keycode":87)]}
move_backward={"deadzone":0.5,"events":[Object(InputEventKey,"physical_keycode":83)]}
move_left={"deadzone":0.5,"events":[Object(InputEventKey,"physical_keycode":65)]}
move_right={"deadzone":0.5,"events":[Object(InputEventKey,"physical_keycode":68)]}
sprint={"deadzone":0.5,"events":[Object(InputEventKey,"physical_keycode":4194325)]}

interact={"deadzone":0.5,"events":[Object(InputEventKey,"physical_keycode":69)]}
demo_complete_quest={"deadzone":0.5,"events":[Object(InputEventKey,"physical_keycode":67)]}
save_game={"deadzone":0.5,"events":[Object(InputEventKey,"physical_keycode":4194338)]}