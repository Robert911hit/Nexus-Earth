; Engine configuration file.
; Nexus Earth uses Godot 4.x and GDScript.

config_version=5

[application]
config/name="Nexus Earth"
config/description="Open-world RPG foundation for Nexus Earth."
run/main_scene="res://scenes/demo/first_playable_demo.tscn"
config/features=PackedStringArray("4.2")

[autoload]
